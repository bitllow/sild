# Sild backend configuration (all settings have defaults; SQLite needs none).

SILD_ENV=development
SILD_HTTP_ADDR=:8080

# Database: postgres | mysql | sqlite
DB_DRIVER=sqlite
DB_DSN=sild.db
DB_LOG_SQL=false

# Examples for other drivers:
# DB_DRIVER=postgres
# DB_DSN=host=localhost port=5432 user=sild password=sild dbname=sild sslmode=disable
# DB_DRIVER=mysql
# DB_DSN=sild:sild@tcp(localhost:3306)/sild?parseTime=true&charset=utf8mb4

# Email channel (§6.2). Each tenant gets a forwarding address
# <inbound_token>@$SILD_EMAIL_INBOUND_DOMAIN; orgs forward their support mailbox
# to it and the sild-mail daemon catches + ingests every message.
SILD_EMAIL_INBOUND_DOMAIN=inbound.sild.local
SILD_SMTP_ADDR=:2525
# Outbound relay for agent replies. Leave RELAY_ADDR empty to disable sending
# (the mailer becomes a no-op — fine for local dev). MailHog: localhost:1025.
# SILD_SMTP_RELAY_ADDR=localhost:1025
# SILD_SMTP_RELAY_USER=
# SILD_SMTP_RELAY_PASS=
SILD_SMTP_FROM=support@inbound.sild.local
