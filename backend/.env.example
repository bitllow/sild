# Sild backend configuration (all settings have defaults; SQLite needs none).

SILD_ENV=development
SILD_HTTP_ADDR=:8080

# Database: postgres | mysql | sqlite
DB_DRIVER=sqlite
DB_DSN=sild.db
DB_LOG_SQL=false

# Examples for other drivers:
# DB_DRIVER=postgres
# DB_DSN=host=localhost port=5432 user=sild password=sild dbname=sild sslmode=disable
# DB_DRIVER=mysql
# DB_DSN=sild:sild@tcp(localhost:3306)/sild?parseTime=true&charset=utf8mb4
